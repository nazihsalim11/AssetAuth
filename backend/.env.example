# ---------------------------------------------------------------------------
# Backend configuration
# ---------------------------------------------------------------------------

# Railway injects PORT automatically; only set this for local development.
PORT=5000

# Set to "production" on the host. This makes the server refuse to start without
# a real JWT_SECRET, and warn when ALLOWED_ORIGINS is missing.
NODE_ENV=development

# ---------------------------------------------------------------------------
# Database (Supabase Postgres)
# ---------------------------------------------------------------------------

# Transaction pooler (port 6543) — used for ordinary queries.
DATABASE_URL=postgresql://[user]:[password]@[host]:6543/postgres

# Direct/session connection (port 5432) — used for migrations and seeding.
# Falls back to DATABASE_URL when unset, but pooled connections cannot run
# some DDL reliably, so set it explicitly.
DIRECT_URL=postgresql://[user]:[password]@[host]:5432/postgres

# ---------------------------------------------------------------------------
# Auth
# ---------------------------------------------------------------------------

# REQUIRED in production. There is a development fallback in server.js, but it is
# committed to this repository, so anyone could forge a token for any user.
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Comma-separated list of origins allowed to call this API.
# Leave empty for local development (any origin is accepted).
# ALLOWED_ORIGINS=https://your-app.vercel.app,https://www.your-domain.com
ALLOWED_ORIGINS=

# Set to "true" ONLY for local integration testing. It lets callers authenticate
# with x-user-role / x-user-id headers, which anyone can forge.
ALLOW_HEADER_AUTH=false

# ---------------------------------------------------------------------------
# File storage (Supabase Storage)
# ---------------------------------------------------------------------------
# When both values are set, uploads go to a PRIVATE bucket and are read through
# short-lived signed URLs. When unset, files fall back to backend/public/uploads,
# which is fine locally but does NOT survive a redeploy on a hosted container.

SUPABASE_URL=https://[project-ref].supabase.co

# Service-role key. Bypasses row-level security — server only, never the browser.
# Supabase dashboard -> Project Settings -> API -> service_role
SUPABASE_SERVICE_ROLE_KEY=

# Bucket name. Create it as a PRIVATE bucket in the Supabase dashboard.
SUPABASE_STORAGE_BUCKET=documents

# How long a signed file link stays valid, in seconds.
SIGNED_URL_TTL_SECONDS=120
