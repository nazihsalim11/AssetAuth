# ---------------------------------------------------------------------------
# Backend configuration
# ---------------------------------------------------------------------------

# Most hosts inject PORT automatically; only set this for local development.
PORT=5000

# Set to "production" on the host. This makes the server refuse to start without
# a real JWT_SECRET, and warn when ALLOWED_ORIGINS is missing.
NODE_ENV=development

# ---------------------------------------------------------------------------
# Database & File Storage (Convex)
# ---------------------------------------------------------------------------

# The deployment URL of your Convex project.
# In production, this will look like: https://[your-project].convex.cloud
# In local development (with self-hosted/local dev), it might look like: http://localhost:3210
CONVEX_URL=

# ---------------------------------------------------------------------------
# Auth
# ---------------------------------------------------------------------------

# REQUIRED in production. There is a development fallback in server.js, but it is
# committed to this repository, so anyone could forge a token for any user.
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Comma-separated list of origins allowed to call this API.
# Leave empty for local development (any origin is accepted).
# ALLOWED_ORIGINS=https://asset-auth.vercel.app
ALLOWED_ORIGINS=

# Set to "true" ONLY for local integration testing. It lets callers authenticate
# with x-user-role / x-user-id headers, which anyone can forge.
ALLOW_HEADER_AUTH=false

# The public URL of the frontend. Used as the OAuth/callback base and as the
# post-logout destination. Set this to your deployed site in production
# (e.g. https://asset-auth.vercel.app).
FRONTEND_URL=http://localhost:5173

# ---------------------------------------------------------------------------
# WorkOS (authentication provider)
# ---------------------------------------------------------------------------
# Login uses WorkOS User Management with EMBEDDED password authentication
# (userManagement.authenticateWithPassword) — users sign in on the app's own login
# page, no hosted redirect. WorkOS is the sole owner of credentials; the app never
# stores passwords. WORKOS_API_KEY is required; without it, password login is disabled.
#
# In the WorkOS dashboard (Configuration > Authentication) enable "Email + Password".
# In Redirects, set:
#   - App homepage URL:   ${FRONTEND_URL}                 (fixes the logout error page)
#   - Redirect URI:       ${FRONTEND_URL}/api/auth/callback   (legacy hosted flow)
#   - Logout redirect:    ${FRONTEND_URL}
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
WORKOS_REDIRECT_URI=http://localhost:5173/api/auth/callback

# The one account bootstrapped as Super Admin the first time it signs in. Every other
# first-time WorkOS user is provisioned as Employee; roles are then owned by the app
# database and only a Super Admin can change them (never yourself). Create this user in
# WorkOS with a password, then sign in once to seed the Super Admin profile.
BOOTSTRAP_ADMIN_EMAIL=admin@company.com

# ---------------------------------------------------------------------------
# Scheduled jobs
# ---------------------------------------------------------------------------
# By default the API runs its own schedules with node-cron: a daily expiry sweep,
# an hourly SLA check, and a retry of failed sends every 15 minutes.
#
# node-cron only fires while this process is alive. On a host that sleeps an idle
# web service (Render's free tier, for one) the schedules stop silently. There,
# drive the jobs over HTTP instead:
#
#   1. DISABLE_INTERNAL_CRON=true
#   2. CRON_SECRET=<32+ random characters>
#   3. Trigger the endpoints /api/internal/cron/* via an external cron service.
#
# Setting DISABLE_INTERNAL_CRON=true WITHOUT a CRON_SECRET means nothing is
# scheduled at all, in-process or over HTTP. The server logs an error on boot if
# you do that, but it will not stop you.
DISABLE_INTERNAL_CRON=false

# Shared secret for POST /api/internal/cron/*. Must be at least 16 characters, or
# the endpoints reject every request (they fail closed rather than open).
#   node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
CRON_SECRET=

# ---------------------------------------------------------------------------
# Notifications
# ---------------------------------------------------------------------------
# Email: leave SMTP_HOST unset and messages are logged and written to the in-app
# Email Alerts Inbox, but never actually sent. That is the safe default for local
# development. Works with any SMTP provider — Mailtrap is a good choice for testing
# without delivering to real inboxes.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=AssetFlow <no-reply@assetflow.local>

# SMS is optional. With any of these unset the channel reports itself unconfigured,
# deliveries are recorded as 'Skipped' rather than 'Failed', and nothing is retried.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
